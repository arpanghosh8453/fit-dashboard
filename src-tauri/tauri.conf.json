{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FIT Dashboard",
  "version": "0.1.0",
  "identifier": "com.local.fitdashboard",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "features": ["tauri-app"],
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "windows": [
      {
        "title": "FIT Dashboard",
        "width": 1200,
        "height": 800,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "icon": [
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png",
      "icons/icon.svg"
    ]
  }
}
